{
  "version": "2026-06-14.2",
  "broadMinFilters": 2,
  "defaultSort": { "key": "assessed_value", "dir": "asc" },
  "sortKeys": [
    { "key": "pin", "field": "pin" },
    { "key": "lot_size", "field": "land_sqft" },
    { "key": "building_size", "field": "bldg_sqft" },
    { "key": "year_built", "field": "year_built" },
    { "key": "assessed_value", "field": "total_assessed_value_sortkey" },
    { "key": "last_sale_price", "field": "last_sale_price" },
    { "key": "sale_recency", "field": "sale_recency_days" },
    { "key": "price_per_sf", "field": "price_per_sf" },
    { "key": "value_percentile", "field": "value_percentile" },
    { "key": "upside_score", "field": "upside_score" }
  ],
  "topics": [
    { "id": "vacant_mf_transit", "label": "Vacant land, MF-zoned, near transit",
      "description": "Empty lots in RM/RT multifamily zoning within ½ mile of an L stop.",
      "presets": {
        "vacancy": { "kind": "flag", "value": true },
        "zoning_group": { "kind": "enum", "values": ["residential"] },
        "transit_proximity": { "kind": "range", "max": 0.5 },
        "lot_size": { "kind": "range", "min": 3000 }
      },
      "defaultSort": { "key": "lot_size", "dir": "desc" } },

    { "id": "teardown", "label": "Teardown candidates",
      "description": "Buildings worth far less than their land — classic land plays.",
      "presets": {
        "is_teardown_candidate": { "kind": "flag", "value": true },
        "land_use": { "kind": "enum", "values": ["residential", "multi_family"] }
      },
      "defaultSort": { "key": "upside_score", "dir": "desc" } },

    { "id": "undervalued_mf", "label": "Undervalued multifamily",
      "description": "2–6 flats in the bottom quartile of $/sq ft for their neighborhood.",
      "presets": {
        "land_use": { "kind": "enum", "values": ["multi_family"] },
        "value_percentile": { "kind": "range", "max": 25 }
      },
      "defaultSort": { "key": "value_percentile", "dir": "asc" } },

    { "id": "underused_commercial_tif", "label": "Underused commercial in a TIF",
      "description": "Cheapest under-built commercial parcels inside a TIF district.",
      "presets": {
        "land_use": { "kind": "enum", "values": ["commercial"] },
        "tif": { "kind": "flag", "value": true },
        "upside_score": { "kind": "range", "min": 40 }
      },
      "defaultSort": { "key": "upside_score", "dir": "desc" } },

    { "id": "fresh_comps", "label": "Fresh comps (sold < 6 mo)",
      "description": "Recent multifamily & commercial sales for underwriting.",
      "presets": {
        "sale_recency": { "kind": "range", "max": 180 },
        "land_use": { "kind": "enum", "values": ["multi_family", "commercial"] }
      },
      "defaultSort": { "key": "sale_recency", "dir": "asc" } },

    { "id": "adu_2flats", "label": "ADU-eligible 2–4 flats",
      "description": "Small multifamily on ADU-eligible blocks — add a coach house.",
      "presets": {
        "land_use": { "kind": "enum", "values": ["multi_family"] },
        "units": { "kind": "range", "min": 2, "max": 4 },
        "adu_eligible": { "kind": "flag", "value": true }
      },
      "defaultSort": { "key": "lot_size", "dir": "desc" } }
  ],
  "filters": [
    { "id": "neighborhood", "category": "location", "kind": "region", "field": "neighborhood", "unknownPolicy": "exclude",
      "label": "Neighborhood", "help": "Chicago community area." },
    { "id": "ward", "category": "location", "kind": "region", "field": "ward", "unknownPolicy": "exclude",
      "label": "Ward" },
    { "id": "radius", "category": "location", "kind": "region", "field": "centroid", "unknownPolicy": "exclude",
      "label": "Within radius", "help": "Parcels within a distance of a point." },
    { "id": "transit_proximity", "category": "location", "kind": "range", "field": "cta_rail_distance_mi", "unit": "mi", "unknownPolicy": "exclude",
      "label": "Near transit", "help": "Distance to the nearest CTA rail (L) station.",
      "range": { "domain": [0, 3], "step": 0.1, "boundMode": "max", "display": "mi",
        "presets": [ { "label": "¼ mi", "max": 0.25 }, { "label": "½ mi", "max": 0.5 }, { "label": "1 mi", "max": 1 } ] } },

    { "id": "land_use", "category": "property_use", "kind": "enum", "field": "land_use_class", "unknownPolicy": "exclude",
      "label": "Property use",
      "enumValues": ["vacant", "residential", "multi_family", "commercial", "industrial", "mixed_use", "institutional", "exempt"],
      "enumLabels": { "vacant": "Vacant land", "residential": "Residential", "multi_family": "Multifamily", "commercial": "Commercial", "industrial": "Industrial", "mixed_use": "Mixed-use", "institutional": "Institutional", "exempt": "Tax-exempt" } },
    { "id": "vacancy", "category": "property_use", "kind": "flag", "field": "is_vacant", "unknownPolicy": "exclude", "contradicts": ["building_size"],
      "label": "Vacant", "help": "No building of record on the parcel." },
    { "id": "lot_size", "category": "property_use", "kind": "range", "field": "land_sqft", "unit": "sqft", "unknownPolicy": "exclude",
      "label": "Lot size", "range": { "domain": [0, 50000], "step": 100, "boundMode": "both", "display": "number" } },
    { "id": "building_size", "category": "property_use", "kind": "range", "field": "bldg_sqft", "unit": "sqft", "unknownPolicy": "exclude",
      "label": "Building size", "range": { "domain": [0, 100000], "step": 100, "boundMode": "both", "display": "number" } },
    { "id": "year_built", "category": "property_use", "kind": "range", "field": "year_built", "unit": "year", "unknownPolicy": "exclude",
      "label": "Year built", "range": { "domain": [1850, 2025], "step": 1, "boundMode": "both", "display": "year" } },
    { "id": "units", "category": "property_use", "kind": "range", "field": "units", "unit": "units", "unknownPolicy": "exclude",
      "label": "Units", "range": { "domain": [0, 100], "step": 1, "boundMode": "both", "display": "count" } },

    { "id": "zoning_group", "category": "zoning_dev", "kind": "enum", "field": "zoning_group", "unknownPolicy": "exclude",
      "label": "Zoning group",
      "enumValues": ["residential", "business", "commercial", "manufacturing", "downtown", "planned_development"],
      "enumLabels": { "residential": "Residential (R)", "business": "Business (B)", "commercial": "Commercial (C)", "manufacturing": "Manufacturing (M)", "downtown": "Downtown (D)", "planned_development": "Planned Development (PD)" } },
    { "id": "density_band", "category": "zoning_dev", "kind": "range", "field": "density_band", "unit": "far", "unknownPolicy": "exclude", "contradicts": [], "requires": ["zoning_group"],
      "label": "Density (FAR)", "help": "Allowed floor-area ratio for the parcel's zoning. Pick a zoning group first.",
      "range": { "domain": [0, 16], "step": 0.5, "boundMode": "both", "display": "far" } },
    { "id": "overlay", "category": "zoning_dev", "kind": "enum", "field": "overlay", "unknownPolicy": "exclude",
      "label": "Overlay district",
      "enumValues": ["planned_development", "landmark", "historic", "pedestrian_street", "pmd"],
      "enumLabels": { "planned_development": "Planned Development", "landmark": "Landmark", "historic": "Historic", "pedestrian_street": "Pedestrian street", "pmd": "Planned Manufacturing District" } },
    { "id": "adu_eligible", "category": "zoning_dev", "kind": "flag", "field": "in_adu_area", "unknownPolicy": "exclude",
      "label": "ADU-eligible", "help": "On a block where Additional Dwelling Units (coach houses / conversions) are allowed." },
    { "id": "aro_zone", "category": "zoning_dev", "kind": "flag", "field": "in_aro_zone", "unknownPolicy": "exclude",
      "label": "ARO zone", "help": "In an Affordable Requirements Ordinance area (on-site affordable set-aside applies)." },
    { "id": "upside_score", "category": "zoning_dev", "kind": "range", "field": "upside_score", "unknownPolicy": "exclude",
      "label": "Redevelopment upside", "help": "0–100 blend of unused zoning capacity (FAR headroom) and land-vs-building value. Higher = more room to add density or rebuild.",
      "range": { "domain": [0, 100], "step": 5, "boundMode": "min", "display": "score",
        "presets": [ { "label": "Med 40+", "min": 40 }, { "label": "High 70+", "min": 70 } ] } },
    { "id": "is_teardown_candidate", "category": "zoning_dev", "kind": "flag", "field": "is_teardown_candidate", "unknownPolicy": "exclude",
      "label": "Teardown candidate", "help": "Improvement worth ≤25% of total value — the building is a fraction of the land's worth." },

    { "id": "tif", "category": "incentives", "kind": "flag", "field": "in_tif_district", "unknownPolicy": "exclude",
      "label": "TIF district", "help": "Inside a Tax Increment Financing district." },
    { "id": "opportunity_zone", "category": "incentives", "kind": "flag", "field": "in_opportunity_zone", "unknownPolicy": "exclude",
      "label": "Opportunity Zone", "help": "Federal Qualified Opportunity Zone (capital-gains incentive)." },
    { "id": "enterprise_zone", "category": "incentives", "kind": "flag", "field": "in_enterprise_zone", "unknownPolicy": "exclude",
      "label": "Enterprise Zone", "help": "Illinois Enterprise Zone (sales/property-tax incentives)." },
    { "id": "sbif_nof", "category": "incentives", "kind": "flag", "field": "in_sbif_nof_area", "unknownPolicy": "exclude",
      "label": "SBIF / NOF grants", "help": "In a Small Business Improvement Fund or Neighborhood Opportunity Fund grant area." },

    { "id": "assessed_value", "category": "financial", "kind": "range", "field": "total_assessed_value", "unit": "usd", "unknownPolicy": "exclude",
      "label": "Assessed value", "range": { "domain": [0, 5000000], "step": 1000, "boundMode": "both", "display": "usd" } },
    { "id": "last_sale_price", "category": "financial", "kind": "range", "field": "last_sale_price", "unit": "usd", "unknownPolicy": "exclude",
      "label": "Last sale price", "range": { "domain": [0, 5000000], "step": 1000, "boundMode": "both", "display": "usd" } },
    { "id": "sale_recency", "category": "financial", "kind": "range", "field": "sale_recency_days", "unit": "days", "unknownPolicy": "exclude",
      "label": "Sold within", "help": "Time since the last recorded sale.",
      "range": { "domain": [0, 1825], "step": 30, "boundMode": "max", "display": "number",
        "presets": [ { "label": "3 mo", "max": 90 }, { "label": "6 mo", "max": 180 }, { "label": "12 mo", "max": 365 }, { "label": "24 mo", "max": 730 } ] } },
    { "id": "price_per_sf", "category": "financial", "kind": "range", "field": "price_per_sf", "unit": "usd", "unknownPolicy": "exclude",
      "label": "Price per sq ft", "range": { "domain": [0, 1000], "step": 5, "boundMode": "both", "display": "usd" } },
    { "id": "improvement_ratio", "category": "financial", "kind": "range", "field": "improvement_ratio", "unit": "ratio", "unknownPolicy": "exclude",
      "label": "Improvement ratio", "help": "Building value as a share of total assessed value. Low = land dominates (a teardown signal).",
      "range": { "domain": [0, 1], "step": 0.05, "boundMode": "both", "display": "percent" } },
    { "id": "value_percentile", "category": "financial", "kind": "range", "field": "value_percentile", "unit": "percentile", "unknownPolicy": "exclude",
      "label": "Undervalued vs. neighborhood", "help": "Rank of the parcel's $/sq ft among same-use parcels in its community area. Lower = cheaper than its peers.",
      "range": { "domain": [0, 100], "step": 1, "boundMode": "max", "display": "percent",
        "presets": [ { "label": "Bottom 10%", "max": 10 }, { "label": "Bottom 25%", "max": 25 }, { "label": "Bottom 50%", "max": 50 } ] } },

    { "id": "open_violations", "category": "condition_risk", "kind": "range", "field": "open_violation_count", "unit": "count", "unknownPolicy": "exclude",
      "label": "Open building violations", "range": { "domain": [0, 50], "step": 1, "boundMode": "both", "display": "count" } },
    { "id": "f311_redflags", "category": "condition_risk", "kind": "range", "field": "f311_redflag_count", "unit": "count", "unknownPolicy": "exclude",
      "label": "311 red-flag complaints", "help": "Count of serious 311 complaints (e.g. vacant/dangerous building).",
      "range": { "domain": [0, 50], "step": 1, "boundMode": "both", "display": "count" } },
    { "id": "floodplain", "category": "condition_risk", "kind": "flag", "field": "in_special_flood_hazard", "unknownPolicy": "exclude",
      "label": "Floodplain", "help": "In a FEMA Special Flood Hazard Area." },
    { "id": "brownfield", "category": "condition_risk", "kind": "flag", "field": "near_brownfield", "unknownPolicy": "exclude",
      "label": "Near brownfield", "help": "Near a known contaminated / brownfield site." },
    { "id": "crime_index", "category": "condition_risk", "kind": "range", "field": "crime_index", "unit": "index", "unknownPolicy": "exclude",
      "label": "Crime index", "help": "Normalized 0–100 crime intensity near the parcel (higher = more).",
      "range": { "domain": [0, 100], "step": 1, "boundMode": "both", "display": "score" } }
  ]
}
