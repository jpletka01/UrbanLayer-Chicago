{
  "queries": [
    {
      "id": "crime_coverage",
      "question": "What crimes have been reported in West Town in the last 90 days?",
      "category": "socrata_flat",
      "checks": [
        {
          "sub_source": "crime_api",
          "context_fields": ["crime_last_90d.total", "crime_last_90d.arrest_rate", "crime_last_90d.by_type"],
          "synthesis_patterns": {
            "patterns": ["\\d+.*(?:crime|incident|offense|report)"],
            "any_of_groups": [["theft", "battery", "assault", "burglary", "robbery", "motor vehicle", "narcotics", "criminal"]]
          }
        }
      ]
    },
    {
      "id": "311_coverage",
      "question": "What are the open 311 complaints in Englewood?",
      "category": "socrata_flat",
      "checks": [
        {
          "sub_source": "311_api",
          "context_fields": ["open_311_requests.total", "open_311_requests.top_types"],
          "synthesis_patterns": {
            "patterns": ["\\d+.*(?:311|request|complaint|service)"],
            "any_of_groups": [["street light", "pothole", "garbage", "rodent", "graffiti", "water", "weed", "tree", "vacant", "abandoned"]]
          }
        }
      ]
    },
    {
      "id": "permits_coverage",
