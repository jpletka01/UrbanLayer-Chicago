.env
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.DS_Store

# Ignore generated data, but allow specific committed artifacts. NOTE: must glob the
# dir CONTENTS (ingestion/data/*), not the dir itself — git cannot re-include a file
# whose parent directory is excluded, so `ingestion/data/` would make the `!` lines below
# silently inert (they only "worked" before because those files were already tracked).
ingestion/data/*
!ingestion/data/.gitkeep
!ingestion/data/transit_stations.json
!ingestion/data/community_areas.geojson
!ingestion/data/zoning_cache.json

backend/data/

node_modules/
dist/
.vite/

# Playwright test run artifacts
test-results/

# Large source files (download separately)
chicago-il-codes.html

# JetBrains IDE
.idea/
